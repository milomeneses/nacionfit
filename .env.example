# Server / Database (Hostinger MySQL)
# Copy this file to server/.env and fill in your real credentials.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mi_cocina

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Server port
PORT=3001
