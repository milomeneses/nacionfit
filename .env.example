# Server / Database (Hostinger MySQL)
# Copy this file to server/.env and fill in your real credentials.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mi_cocina

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Server port
PORT=3001

# Groq (AI coach + Whisper voice). Free key from https://console.groq.com
GROQ_API_KEY=
# Override the API base only for testing/self-hosting (defaults to Groq's cloud)
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Gemini (weekly review). Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
