# Server / Database (Hostinger MySQL)
# Copy this file to server/.env and fill in your real credentials.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mi_cocina

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Server port
PORT=3001

# Groq (AI coach + Whisper voice). Free key from https://console.groq.com
GROQ_API_KEY=
# Override the API base only for testing/self-hosting (defaults to Groq's cloud)
# GROQ_BASE_URL=https://api.groq.com/openai/v1
